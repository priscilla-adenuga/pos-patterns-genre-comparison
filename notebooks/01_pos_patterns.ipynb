import spacy
from collections import Counter

# Load model
nlp = spacy.load("en_core_web_sm")

# Read files
with open("data/news_sample.txt") as f:
    news_text = f.read()

with open("data/tweets_sample.txt") as f:
    tweets_text = f.read()

# Process texts
news_doc = nlp(news_text)
tweets_doc = nlp(tweets_text)

# Function to get POS counts
def get_pos_counts(doc):
    return Counter([token.pos_ for token in doc if token.is_alpha])

news_pos = get_pos_counts(news_doc)
tweets_pos = get_pos_counts(tweets_doc)

print("News POS:", news_pos)
print("Tweets POS:", tweets_pos)
